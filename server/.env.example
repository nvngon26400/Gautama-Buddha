# Sao chép thành server/.env và điền giá trị thật.

# API vision (ít nhất một khóa)
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Thống kê truy cập — trang /admin (Bearer token)
# ADMIN_ANALYTICS_SECRET=đặt-mật-khẩu-dài-ngẫu-nhiên

# Tuỳ chọn: đường dẫn file SQLite (mặc định server/data/analytics.db)
# Trên Vercel serverless có thể dùng /tmp/analytics.db (dữ liệu không bền).
# ANALYTICS_DB_PATH=
