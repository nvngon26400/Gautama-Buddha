# Sao chép thành server/.env và điền giá trị thật.

# API vision (ít nhất một khóa)
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Thống kê truy cập — trang /admin (Bearer token)
# ADMIN_ANALYTICS_SECRET=đặt-mật-khẩu-dài-ngẫu-nhiên

# Tuỳ chọn: đường dẫn file SQLite.
# Local: mặc định server/data/analytics.db
# Trên Vercel: tự dùng /tmp/analytics.db khi có biến VERCEL (do Vercel gán); không cần đặt trừ khi muốn chỗ khác.
# ANALYTICS_DB_PATH=/tmp/analytics.db
